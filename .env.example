# =========================
# Core App
# =========================
DATABASE_URL=sqlite:///./database.db
ENV_VALIDATION_MODE=warn
ENABLE_TEST_ENDPOINTS=false

# =========================
# Vapi
# =========================
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_BASE_URL=https://api.vapi.ai
VAPI_API_URL=https://api.vapi.ai/call
VAPI_ASSISTANT_API_BASE_URL=https://api.vapi.ai/assistant
VAPI_WEBHOOK_URL=
VAPI_WEBHOOK_SECRET=
VAPI_PREFLIGHT_REQUIRED_FOR_CAMPAIGN=true
VAPI_PREFLIGHT_TIMEOUT_SECONDS=15
VAPI_REQUIRE_ASSISTANT_SERVER_CONFIG=true
VAPI_EXPECTED_SERVER_URL=
VAPI_VERIFY_ASSISTANT_BEFORE_CALL=false
VAPI_ASSISTANT_VERIFY_TIMEOUT_SECONDS=10
VAPI_EXPECTED_ASSISTANT_NAME=
VAPI_EXPECTED_PROMPT_CONTAINS=
VAPI_TIMEOUT_SECONDS=25
VAPI_MAX_RETRIES=3
VAPI_CIRCUIT_FAILURE_THRESHOLD=3
VAPI_CIRCUIT_OPEN_SECONDS=30

# =========================
# Twilio / Manager
# =========================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=whatsapp:+14155238886
MANAGER_PHONE_NUMBER=whatsapp:+91XXXXXXXXXX
MANAGER_JOIN_CODE=join your-code
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_MAX_RETRIES=2
TWILIO_CIRCUIT_FAILURE_THRESHOLD=3
TWILIO_CIRCUIT_OPEN_SECONDS=30

# =========================
# Dashboard Security
# =========================
DASHBOARD_API_KEY=
DASHBOARD_API_KEY_HEADER=X-API-Key

# =========================
# Campaign Queue
# =========================
MAX_CONCURRENT_CALLS=1
MAX_CALL_ATTEMPTS=3
JOB_POLL_INTERVAL_SECONDS=0.5
JOB_LEASE_SECONDS=60

# =========================
# Rate Limits (per minute)
# =========================
RATE_LIMIT_DASHBOARD_PER_MINUTE=120
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_CAMPAIGN_PER_MINUTE=20
RATE_LIMIT_WEBHOOK_PER_MINUTE=300

# =========================
# Retention / Idempotency
# =========================
WEBHOOK_DEDUPE_TTL_SECONDS=86400
WEBHOOK_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=30
JOB_RETENTION_DAYS=7

# =========================
# API Security / CORS / Logging
# =========================
SECURITY_HEADERS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
LOG_PII_REDACTION_ENABLED=true

# =========================
# Frontend (Vite)
# =========================
VITE_API_URL=http://127.0.0.1:8000
VITE_ENABLE_TEST_ENDPOINTS=false
VITE_DASHBOARD_API_KEY=
VITE_DASHBOARD_API_KEY_HEADER=X-API-Key
